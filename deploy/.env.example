DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=capitalos
DB_USER=root
DB_PASSWORD=replace-with-deployment-secret

FRONTEND_PORT=8089
BACKEND_PORT=7997
PYTHON_BIN=python3.12

JWT_SECRET=replace-with-strong-random-32-hex
JWT_TTL_SECONDS=28800

# AI / LLM(OpenAI 兼容)—— 填 key 并将 LLM_ENABLED=true 即生效
LLM_ENABLED=false
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=180

# LLM provider 切换(默认 openai = 上面的 OpenAI 兼容配置,行为不变):
#   claude-cli   本机 claude CLI 纯推理(已安装并登录时零配置,不看 LLM_ENABLED)
#   tinci-agent  公司 AI 网关(需配全下方 TINCI_AI_*)
# 任一 provider 调用失败时,若本机 claude 可用会自动兜底 claude-cli(打日志)。
LLM_PROVIDER=openai

# tinci-agent 专属(LLM_PROVIDER=tinci-agent 时必填;AGENT_ID 为大整数,保持字符串)
TINCI_AI_BASE_URL=
TINCI_AI_TOKEN=
TINCI_AI_WORKSPACE_ID=
TINCI_AI_AGENT_ID=
TINCI_AI_MODEL=deepseek-chat
TINCI_AI_MODEL_PROVIDER=deepseek
